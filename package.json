{
  "name": "openstem-ai-audio-workstation",
  "private": true,
  "version": "1.0.0",
  "description": "Independent AI audio workstation for local stem separation and audio workflow tools.",
  "author": "Robert Sawin (GitHub: Trip3980)",
  "main": "electron-shell/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "test": "tsx src/scripts/test-app.ts",
    "validate-registry": "tsx src/scripts/validate-registry.ts",
    "lint:eslint": "eslint \"src/**/*.{ts,tsx}\" \"server.ts\" \"electron-shell/**/*.cjs\"",
    "lint:strict": "tsc -p tsconfig.strict.json --noEmit",
    "format:check": "prettier --check eslint.config.js .prettierrc \"docs/**/*.md\" \"src/scripts/audit-registry-sources.ts\" \"src/scripts/backend-diagnostics.ts\" \"src/scripts/check-proof-readiness.ts\" \"src/scripts/verify-electron-artifacts.ts\"",
    "audit:moderate": "npm audit --audit-level=moderate",
    "audit:model-sources": "tsx src/scripts/audit-registry-sources.ts",
    "diagnostics:backend": "tsx src/scripts/backend-diagnostics.ts",
    "proof:check": "tsx src/scripts/check-proof-readiness.ts",
    "test:ffmpeg": "node electron-shell/test-e2e.cjs",
    "verify:artifacts": "tsx src/scripts/verify-electron-artifacts.ts",
    "release:check": "npm run lint && npm run lint:eslint && npm run format:check && npm run build && npm run test && npm run validate-registry && npm run audit:moderate && npm run audit:model-sources && npm run electron:build && npm run verify:artifacts",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "npm run build && electron-builder",
    "electron:build:dir": "npm run build && electron-builder --dir",
    "electron:build:win": "npm run build && electron-builder --win",
    "electron:build:linux": "npm run build && electron-builder --linux",
    "electron:build:mac": "npm run build && electron-builder --mac",
    "make": "npm run electron:build"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.25.0",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.61.1",
    "vite": "^6.2.3",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.trip3980.openstem-ai-audio-workstation",
    "productName": "OpenStem AI Audio Workstation",
    "directories": {
      "output": "dist-electron"
    },
    "asar": true,
    "files": [
      "dist/**/*",
      "electron-shell/**/*",
      "package.json",
      "README.md",
      "LICENSE",
      "THIRD_PARTY_NOTICES.md",
      "!**/.env*",
      "!**/.venv*/**",
      "!**/.openstem-backend/**",
      "!**/uvr_models/**",
      "!**/models/**",
      "!**/.cache/**",
      "!**/cache/**",
      "!**/sandbox_cache/**",
      "!**/tmp_test_runs/**",
      "!**/OpenStemProofOutput/**",
      "!**/proof_output/**",
      "!**/proof_outputs/**",
      "!**/*.log"
    ],
    "extraResources": [
      {
        "from": "scripts",
        "to": "scripts",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!**/.venv*/**",
          "!**/.env*"
        ]
      },
      {
        "from": "LICENSE",
        "to": "LICENSE"
      },
      {
        "from": "THIRD_PARTY_NOTICES.md",
        "to": "THIRD_PARTY_NOTICES.md"
      },
      {
        "from": "README.md",
        "to": "README.md"
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.music"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName} Setup ${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OpenStem AI Audio Workstation"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Audio",
      "artifactName": "${productName} ${version}.${ext}"
    }
  }
}
